generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAVELER
  OPERATOR
  ADMIN
}

enum Difficulty {
  EASY
  MODERATE
  CHALLENGING
  EXTREME
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
}

enum SlotStatus {
  OPEN
  FILLING_FAST
  CONFIRMED
  FULL
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum PosHStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  PROCESSING
  RESOLVED_OPERATOR
  RESOLVED_CUSTOMER
  RESOLVED_PARTIAL
}

enum DisputeActor {
  TRAVELER
  OPERATOR
}

enum BookingSource {
  PLATFORM
  OPERATOR_IMPORT
}

enum AgeBand {
  UNDER_18
  AGE_18_25
  AGE_26_35
  AGE_36_50
  AGE_50_PLUS
}

enum TripUpdateType {
  INFO
  LOGISTICS
  WEATHER
  URGENT
}

model User {
  id           String      @id @default(cuid())
  clerkId      String?     @unique
  email        String      @unique
  name         String
  role         UserRole    @default(TRAVELER)
  homeCity     String?
  fitnessLevel Difficulty?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  operator Operator?
  bookings Booking[]
}

model Operator {
  id                 String             @id @default(cuid())
  userId             String             @unique
  slug               String             @unique
  businessName       String
  baseCity           String
  bio                String             @db.Text
  /** Public profile photo / logo (guide or brand mark) */
  logoUrl            String?
  /** Full-bleed profile banner; falls back to trip photos then theme default */
  bannerUrl          String?
  yearsOperating     Int?
  panNumber          String?
  gstNumber          String?
  mtdcRegistrationNo String?
  insuranceStatus    Boolean            @default(false)
  insuranceProvider  String?
  insuranceDetails   String?            @db.Text
  femaleGuideCount   Int                @default(0)
  totalGuideCount    Int                @default(0)
  posHPolicyStatus   PosHStatus         @default(NOT_STARTED)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  phoneVerified      Boolean            @default(false)
  completedTrips     Int                @default(0)
  avgResponseMins    Int                @default(30)
  ratingAvg          Float              @default(0)
  ratingCount        Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings  Listing[]
  payouts   Payout[]
  guides    Guide[]
  vehicles  Vehicle[]
  tripUpdates TripUpdate[]
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  icon     String?
  listings Listing[]
}

model Place {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  city        String
  district    String
  state       String   @default("Maharashtra")
  latitude    Float
  longitude   Float
  elevationM  Int?
  description String   @db.Text
  bestMonths  Int[]
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listings Listing[]

  @@index([city])
}

model Listing {
  id                 String        @id @default(cuid())
  slug               String        @unique
  operatorId         String
  placeId            String
  categoryId         String
  title              String
  summary            String        @db.Text
  description        String        @db.Text
  difficulty         Difficulty
  durationHours      Float
  basePrice          Int
  minGroupSize       Int
  maxGroupSize       Int
  inclusions         String[]
  exclusions         String[]
  thingsToCarry      String[]
  meetingPoint       String?
  cancellationPolicy Json
  attributes         Json?
  heroImageUrl       String?
  galleryUrls        String[]      @default([])
  status             ListingStatus @default(DRAFT)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  operator  Operator           @relation(fields: [operatorId], references: [id])
  place     Place              @relation(fields: [placeId], references: [id])
  category  Category           @relation(fields: [categoryId], references: [id])
  itinerary ItineraryStep[]
  slots     AvailabilitySlot[]
  bookings  Booking[]
  reviews   Review[]

  @@index([categoryId, difficulty])
  @@index([basePrice])
  @@index([status])
}

model ItineraryStep {
  id          String  @id @default(cuid())
  listingId   String
  order       Int
  timeLabel   String?
  title       String
  description String? @db.Text

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, order])
}

model Guide {
  id         String    @id @default(cuid())
  operatorId String
  name       String
  phone      String?
  gender     Gender?
  role       String    @default("Trek lead")
  phonePublic Boolean  @default(false)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  operator Operator           @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  slots    AvailabilitySlot[]

  @@index([operatorId])
}

model Vehicle {
  id         String   @id @default(cuid())
  operatorId String
  type       String
  plate      String
  capacity   Int?
  notes      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  operator Operator           @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  slots    AvailabilitySlot[]

  @@index([operatorId])
}

model AvailabilitySlot {
  id                   String     @id @default(cuid())
  listingId            String
  startTime            DateTime
  endTime              DateTime
  capacity             Int
  bookedSeats          Int        @default(0)
  maleCount            Int        @default(0)
  femaleCount          Int        @default(0)
  otherCount           Int        @default(0)
  minSeatsToConfirm    Int?
  priceOverride        Int?
  status               SlotStatus @default(OPEN)
  meetingPointOverride String?
  pickupNote           String?    @db.Text
  weatherNote          String?    @db.Text
  assignedGuideId      String?
  assignedVehicleId    String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  listing  Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guide    Guide?       @relation(fields: [assignedGuideId], references: [id], onDelete: SetNull)
  vehicle  Vehicle?     @relation(fields: [assignedVehicleId], references: [id], onDelete: SetNull)
  bookings Booking[]
  updates  TripUpdate[]

  @@index([listingId, startTime])
  @@index([assignedGuideId])
  @@index([assignedVehicleId])
}

model Booking {
  id                    String        @id @default(cuid())
  bookingRef            String        @unique
  userId                String
  listingId             String
  slotId                String
  groupSize             Int
  pricePerHead          Int
  totalAmount           Int
  listingTitleSnapshot  String
  startTimeSnapshot     DateTime
  customerEmail         String?
  customerPhone         String?
  customerGender        Gender?
  isRepeatCustomer      Boolean       @default(false)
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalNotes          String?       @db.Text
  source                BookingSource @default(PLATFORM)
  status                BookingStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  listing      Listing              @relation(fields: [listingId], references: [id])
  slot         AvailabilitySlot     @relation(fields: [slotId], references: [id])
  payment      Payment?
  review       Review?
  participants BookingParticipant[]
  updateRead   BookingUpdateRead?

  @@index([userId])
  @@index([listingId])
  @@index([slotId])
  @@index([status])
  @@index([customerEmail])
  @@index([customerPhone])
}

model BookingParticipant {
  id        String    @id @default(cuid())
  bookingId String
  name      String
  gender    Gender?
  ageBand   AgeBand?
  age       Int?
  checkInAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model TripUpdate {
  id         String         @id @default(cuid())
  slotId     String
  operatorId String
  title      String
  body       String         @db.Text
  type       TripUpdateType @default(INFO)
  pinned     Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  slot     AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  operator Operator         @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([slotId, createdAt])
  @@index([operatorId])
}

model BookingUpdateRead {
  bookingId  String   @id
  lastReadAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id                    String         @id @default(cuid())
  bookingId             String         @unique
  amount                Int
  razorpayOrderId       String         @unique
  razorpayPaymentId     String?
  razorpayRefundId      String?
  status                PaymentStatus  @default(CREATED)
  refundedAmount        Int?
  escrowStatus          EscrowStatus?
  heldAt                DateTime?
  releasedAt            DateTime?
  disputeReason         String?        @db.Text
  disputeStatus         DisputeStatus?
  disputeOpenedBy       DisputeActor?
  disputeCreatedAt      DateTime?
  disputeResolutionNote String?        @db.Text
  disputeResolvedAt     DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
  payout  Payout?

  @@index([escrowStatus])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  listingId String
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id])

  @@index([listingId])
}

model Payout {
  id          String       @id @default(cuid())
  operatorId  String
  paymentId   String?      @unique
  amount      Int
  commission  Int
  netAmount   Int
  status      PayoutStatus @default(PENDING)
  referenceId String?
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id])
  payment  Payment? @relation(fields: [paymentId], references: [id])

  @@index([operatorId])
}
